<!DOCTYPE html>
<html>
  <head>
    <base target="_top">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>注文書OCR登録アプリ</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
      .loader { border-top-color: #3498db; animation: spinner 1.5s linear infinite; }
      @keyframes spinner { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
      body.modal-open { overflow: hidden; }
      .tab-active { border-bottom: 2px solid #2563eb; color: #2563eb; font-weight: bold; }
      th, td { white-space: nowrap; }
    </style>
  </head>
  <body class="bg-gray-50 min-h-screen text-gray-800 pb-20">
    <div class="container mx-auto px-2 py-4 max-w-5xl">
      
      <!-- ヘッダー -->
      <div class="mb-6 flex flex-col items-center">
        <h1 class="text-2xl font-bold text-blue-600 mb-2">
          <i class="fas fa-file-invoice-dollar mr-2"></i>注文書 OCR登録
        </h1>
        <div class="flex items-center bg-white px-4 py-2 rounded-full shadow-sm border border-gray-100">
          <a id="ss-link" href="#" target="_blank" class="text-xs text-green-600 font-bold hover:text-green-700 transition flex items-center">
            <i class="fas fa-external-link-alt mr-1"></i>スプレッドシートを開く
          </a>
        </div>
      </div>

      <!-- タブナビゲーション -->
      <div class="flex border-b border-gray-200 mb-6 bg-white rounded-t-lg shadow-sm">
        <button onclick="switchTab('scan')" id="tab-scan" class="flex-1 py-3 px-4 text-sm font-medium tab-active transition">
          <i class="fas fa-camera mr-2"></i>スキャン登録
        </button>
        <button onclick="switchTab('history')" id="tab-history" class="flex-1 py-3 px-4 text-sm font-medium text-gray-500 transition">
          <i class="fas fa-history mr-2"></i>履歴・削除
        </button>
      </div>

      <!-- スキャン登録画面 -->
      <div id="view-scan">
        <div class="bg-white rounded-lg shadow-sm p-4 mb-6 border border-gray-200">
          <label for="file-upload" class="flex flex-col items-center justify-center w-full h-32 border-2 border-blue-100 border-dashed rounded-lg cursor-pointer bg-blue-50 hover:bg-blue-100 transition group">
            <div class="flex flex-col items-center justify-center">
              <i class="fas fa-plus-circle text-3xl text-blue-400 mb-2 group-hover:scale-110 transition-transform"></i>
              <p class="text-sm text-blue-600 font-bold">写真を追加撮影 / 選択</p>
              <p class="text-[10px] text-gray-400 mt-1">1枚ずつ撮影して追加できます</p>
            </div>
            <input id="file-upload" type="file" class="hidden" accept="image/*" multiple onchange="handleFileSelect(this)" />
          </label>
          
          <button id="analyze-btn" onclick="startBatchOcr()" disabled class="w-full mt-4 bg-gray-300 text-white font-bold py-3 px-4 rounded transition shadow-sm">
            画像を選択してください
          </button>

          <div id="file-list-area" class="mt-4 hidden">
            <div class="flex justify-between items-center mb-2 px-1">
              <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">解析待ちリスト (<span id="file-count-badge">0</span>)</h3>
              <button onclick="clearSelection()" class="text-[10px] text-red-500 font-bold hover:underline">
                <i class="fas fa-trash-alt mr-1"></i>すべて消去
              </button>
            </div>
            <ul id="file-list" class="text-xs text-gray-600 space-y-1 max-h-48 overflow-y-auto bg-gray-50 p-2 rounded border border-gray-100">
              <!-- ファイルリストがここに表示される -->
            </ul>
          </div>
        </div>

        <div id="results-container" class="space-y-4">
          <!-- 解析結果のカードがここに動的に追加される -->
        </div>
      </div>

      <!-- 履歴画面 -->
      <div id="view-history" class="hidden">
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
          <div class="p-4 border-b flex justify-between items-center bg-gray-50">
            <h2 class="font-bold text-sm text-gray-700"><i class="fas fa-list-ul mr-2"></i>最近の読み取りデータ</h2>
            <button onclick="loadHistory()" class="text-blue-600 text-xs font-bold hover:bg-blue-50 px-3 py-1 rounded transition">
              <i class="fas fa-sync-alt mr-1"></i>更新
            </button>
          </div>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200 text-xs">
              <thead class="bg-gray-100">
                <tr>
                  <th class="px-3 py-3 text-left font-bold text-gray-600">登録日時</th>
                  <th class="px-3 py-3 text-left font-bold text-gray-600">品番</th>
                  <th class="px-3 py-3 text-right font-bold text-gray-600">数量</th>
                  <th class="px-3 py-3 text-left font-bold text-gray-600">納期</th>
                  <th class="px-3 py-3 text-left font-bold text-gray-600">客先</th>
                  <th class="px-3 py-3 text-left font-bold text-gray-600">注文番号</th>
                  <th class="px-3 py-3 text-center font-bold text-gray-600">削除</th>
                </tr>
              </thead>
              <tbody id="history-table-body" class="bg-white divide-y divide-gray-200">
                <!-- 履歴データ -->
              </tbody>
            </table>
          </div>
          <div id="history-loading" class="p-12 text-center text-gray-500 hidden">
            <div class="loader rounded-full border-2 h-6 w-6 mb-2 mx-auto"></div>
            読み込み中...
          </div>
          <div id="history-empty" class="p-12 text-center text-gray-400 font-medium italic">
            データがありません
          </div>
        </div>
      </div>
    </div>

    <!-- 編集・確認モーダル -->
    <div id="edit-modal" class="fixed inset-0 z-50 hidden overflow-y-auto">
      <div class="flex items-center justify-center min-h-screen px-4 py-6">
        <div class="fixed inset-0 bg-gray-900 bg-opacity-60 transition-opacity" onclick="closeModal()"></div>
        <div class="relative bg-white rounded-xl shadow-2xl max-w-lg w-full p-6 transform transition-all">
          <div class="flex justify-between items-center mb-4 border-b pb-3">
            <h3 class="text-lg font-bold text-gray-800 flex items-center">
              <i class="fas fa-check-circle text-green-500 mr-2"></i>内容の確認・修正
            </h3>
            <button onclick="closeModal()" class="text-gray-400 hover:text-gray-600 transition">
              <i class="fas fa-times"></i>
            </button>
          </div>
          
          <form id="modal-form" class="space-y-4">
            <input type="hidden" name="itemIndex">
            <input type="hidden" name="fileName">
            
            <div>
              <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">品番 / Part Number</label>
              <input type="text" name="partNumber" class="w-full border-2 border-gray-100 p-2 rounded-lg bg-yellow-50 font-bold focus:border-blue-400 outline-none transition">
            </div>
            
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">数量 / Qty</label>
                <input type="number" name="quantity" class="w-full border-2 border-gray-100 p-2 rounded-lg focus:border-blue-400 outline-none transition">
              </div>
              <div>
                <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">納期 / Delivery</label>
                <input type="date" name="deliveryDate" class="w-full border-2 border-gray-100 p-2 rounded-lg focus:border-blue-400 outline-none transition">
              </div>
            </div>
            
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">受注日 / Order Date</label>
                <input type="date" name="orderDate" class="w-full border-2 border-gray-100 p-2 rounded-lg focus:border-blue-400 outline-none transition">
              </div>
              <div>
                <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">製番 / Seiban</label>
                <input type="text" name="mfgNumber" class="w-full border-2 border-gray-100 p-2 rounded-lg focus:border-blue-400 outline-none transition">
              </div>
            </div>
            
            <div>
              <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">客先名 / Customer</label>
              <input type="text" name="customer" class="w-full border-2 border-gray-100 p-2 rounded-lg focus:border-blue-400 outline-none transition">
            </div>
            
            <div>
              <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">注文番号 / Order No</label>
              <input type="text" name="orderNumber" class="w-full border-2 border-gray-100 p-2 rounded-lg focus:border-blue-400 outline-none transition">
            </div>
          </form>
          
          <div class="mt-8 flex flex-col gap-2">
            <button onclick="saveFromModal()" class="w-full bg-green-600 hover:bg-green-700 text-white py-3 rounded-lg font-bold shadow-lg transition transform active:scale-95 flex items-center justify-center">
              <i class="fas fa-save mr-2"></i>スプレッドシートに保存
            </button>
            <div class="flex gap-2">
              <button onclick="discardResultFromModal()" class="flex-1 bg-red-50 text-red-600 py-2 rounded-lg font-bold hover:bg-red-100 transition flex items-center justify-center border border-red-100">
                <i class="fas fa-trash-alt mr-2"></i>この解析結果を破棄
              </button>
              <button onclick="closeModal()" class="flex-1 bg-gray-100 text-gray-600 py-2 rounded-lg font-bold hover:bg-gray-200 transition">
                閉じる
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- グローバルローディング -->
    <div id="loading" class="hidden fixed inset-0 bg-gray-900 bg-opacity-70 flex items-center justify-center z-[60]">
      <div class="bg-white p-8 rounded-2xl text-center shadow-2xl max-w-xs w-full">
        <div class="loader rounded-full border-4 h-12 w-12 mb-4 mx-auto"></div>
        <p id="loading-text" class="font-bold text-gray-800">データを処理中...</p>
        <p class="text-[10px] text-gray-400 mt-2 italic">AIが注文内容を精査しています</p>
      </div>
    </div>

    <script>
      let selectedFiles = [];
      let resultsData = [];

      // 初期化: スプレッドシートURLの取得
      window.onload = function() {
        google.script.run.withSuccessHandler(url => {
          const link = document.getElementById('ss-link');
          link.href = url;
        }).getSpreadsheetUrl();
      };

      // タブ切り替え
      function switchTab(t) {
        document.getElementById('view-scan').classList.toggle('hidden', t !== 'scan');
        document.getElementById('view-history').classList.toggle('hidden', t !== 'history');
        document.getElementById('tab-scan').className = t === 'scan' ? 'flex-1 py-3 px-4 text-sm font-medium tab-active transition' : 'flex-1 py-3 px-4 text-sm font-medium text-gray-500 transition';
        document.getElementById('tab-history').className = t === 'history' ? 'flex-1 py-3 px-4 text-sm font-medium tab-active transition' : 'flex-1 py-3 px-4 text-sm font-medium text-gray-500 transition';
        if (t === 'history') loadHistory();
      }

      // 履歴のロード
      function loadHistory() {
        const tbody = document.getElementById('history-table-body');
        const loading = document.getElementById('history-loading');
        const empty = document.getElementById('history-empty');
        
        tbody.innerHTML = '';
        loading.classList.remove('hidden');
        empty.classList.add('hidden');

        google.script.run
          .withSuccessHandler(history => {
            loading.classList.add('hidden');
            if (!history || history.length === 0) {
              empty.classList.remove('hidden');
              return;
            }
            empty.classList.add('hidden');
            history.forEach(item => {
              const tr = document.createElement('tr');
              tr.className = "hover:bg-blue-50/30 transition";
              tr.innerHTML = `
                <td class="px-3 py-4 text-gray-400 font-mono">${item.timestamp}</td>
                <td class="px-3 py-4 font-bold text-gray-800">${item.partNumber || '-'}</td>
                <td class="px-3 py-4 text-right font-bold text-blue-600">${item.quantity || '0'}</td>
                <td class="px-3 py-4 text-gray-600">${item.deliveryDate || '-'}</td>
                <td class="px-3 py-4 text-gray-600 truncate max-w-[150px]" title="${item.customer}">${item.customer || '-'}</td>
                <td class="px-3 py-4 text-gray-500">${item.orderNumber || '-'}</td>
                <td class="px-3 py-4 text-center">
                  <button onclick="deleteItem('${item.rawTimestamp}', '${item.fileName}')" class="text-red-400 hover:text-red-600 hover:bg-red-50 p-2 rounded-full transition">
                    <i class="fas fa-trash-alt"></i>
                  </button>
                </td>
              `;
              tbody.appendChild(tr);
            });
          })
          .withFailureHandler(err => {
            loading.classList.add('hidden');
            alert('履歴の取得に失敗しました: ' + err.message);
          })
          .getHistoryData();
      }

      // 履歴アイテムの削除
      function deleteItem(ts, fn) {
        if (!confirm('スプレッドシートからこのデータを完全に削除しますか？')) return;
        document.getElementById('loading').classList.remove('hidden');
        document.getElementById('loading-text').innerText = "データを削除中...";
        google.script.run.withSuccessHandler(() => {
          document.getElementById('loading').classList.add('hidden');
          loadHistory();
        }).deleteHistoryItem(ts, fn);
      }

      // ファイル選択時の挙動（蓄積型）
      function handleFileSelect(input) {
        if (!input.files.length) return;
        
        const newFiles = Array.from(input.files);
        selectedFiles = [...selectedFiles, ...newFiles];
        input.value = "";
        
        updateFileListUI();
      }

      // ファイルリスト表示の更新
      function updateFileListUI() {
        const btn = document.getElementById('analyze-btn');
        const listArea = document.getElementById('file-list-area');
        const list = document.getElementById('file-list');
        const badge = document.getElementById('file-count-badge');

        if (selectedFiles.length > 0) {
          btn.disabled = false;
          btn.className = "w-full mt-4 bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-4 rounded shadow-lg transition transform active:scale-95";
          btn.innerHTML = `<i class="fas fa-magic mr-2"></i>${selectedFiles.length}枚の画像を解析する`;
          
          badge.innerText = selectedFiles.length;
          listArea.classList.remove('hidden');
          list.innerHTML = selectedFiles.map((f, i) => `
            <li class="border-b border-gray-100 last:border-0 py-2 flex justify-between items-center group">
              <span class="truncate pr-4"><i class="far fa-image mr-2 text-blue-400"></i>${f.name}</span>
              <button onclick="removeSelectedFile(${i})" class="text-gray-300 hover:text-red-500 transition px-2">
                <i class="fas fa-times-circle"></i>
              </button>
            </li>
          `).join('');
        } else {
          btn.disabled = true;
          btn.className = "w-full mt-4 bg-gray-300 text-white font-bold py-3 px-4 rounded transition shadow-sm";
          btn.innerHTML = "画像を選択してください";
          listArea.classList.add('hidden');
        }
      }

      // リストから個別に削除
      function removeSelectedFile(index) {
        selectedFiles.splice(index, 1);
        updateFileListUI();
      }

      // 全件クリア
      function clearSelection() {
        if (selectedFiles.length > 0 && confirm('選択中のファイルをすべて消去しますか？')) {
          selectedFiles = [];
          updateFileListUI();
        }
      }

      // 一括OCR開始
      async function startBatchOcr() {
        if (selectedFiles.length === 0) return;

        document.getElementById('loading').classList.remove('hidden');
        document.getElementById('results-container').innerHTML = '';
        resultsData = [];
        
        const filesToProcess = [...selectedFiles];
        selectedFiles = [];
        updateFileListUI();
        
        for (let i = 0; i < filesToProcess.length; i++) {
          const file = filesToProcess[i];
          document.getElementById('loading-text').textContent = `${i + 1} / ${filesToProcess.length} 枚目を解析中...`;
          
          const result = await new Promise(resolve => {
            const reader = new FileReader();
            reader.onload = e => {
              google.script.run
                .withSuccessHandler(resolve)
                .withFailureHandler(err => resolve({success: false, fileName: file.name, error: err.message}))
                .processImage(e.target.result, file.name);
            };
            reader.readAsDataURL(file);
          });
          
          resultsData.push(result);
          addResultCard(result, i);
        }
        document.getElementById('loading').classList.add('hidden');
      }

      // 解析結果カードの追加
      function addResultCard(res, idx) {
        const div = document.createElement('div');
        div.id = `card-${idx}`;
        div.className = "bg-white rounded-xl shadow-sm border p-4 border-l-4 transition hover:shadow-md " + (res.success ? "border-l-green-500" : "border-l-red-500");
        
        if (res.success) {
          div.innerHTML = `
            <div class="flex justify-between items-start mb-3">
              <h4 class="font-bold text-sm truncate text-gray-700"><i class="far fa-file-alt mr-2 text-blue-500"></i>${res.fileName}</h4>
              <span id="status-${idx}" class="text-[10px] font-bold text-red-500 bg-red-50 px-2 py-1 rounded border border-red-100 shadow-sm animate-pulse">未保存</span>
            </div>
            <div class="grid grid-cols-2 gap-3 text-xs bg-gray-50 p-3 rounded-lg border border-gray-100">
              <div><span class="text-gray-400">品番:</span> <span class="font-bold">${res.data.partNumber || '-'}</span></div>
              <div><span class="text-gray-400">数量:</span> <span class="font-bold text-blue-600 text-sm">${res.data.quantity || '0'}</span></div>
              <div><span class="text-gray-400">客先:</span> <span class="font-bold">${res.data.customer || '-'}</span></div>
              <div><span class="text-gray-400">納期:</span> <span class="font-bold">${res.data.deliveryDate || '-'}</span></div>
            </div>
            <button onclick="openEditModal(${idx})" class="w-full mt-3 bg-white border-2 border-blue-600 text-blue-600 py-2 rounded-lg text-xs font-bold hover:bg-blue-50 transition">
              <i class="fas fa-edit mr-1"></i>内容を確認して保存
            </button>
          `;
        } else {
          div.innerHTML = `
            <div class="flex justify-between items-center">
              <h4 class="font-bold text-sm text-gray-700">${res.fileName}</h4>
              <span class="text-[10px] font-bold text-red-600 bg-red-50 px-2 py-1 rounded">解析失敗</span>
            </div>
            <p class="text-red-500 text-[10px] mt-2 bg-red-50 p-2 rounded border border-red-100">エラー: ${res.error}</p>
          `;
        }
        document.getElementById('results-container').appendChild(div);
      }

      // モーダルを開く
      function openEditModal(idx) {
        const d = resultsData[idx];
        const f = document.getElementById('modal-form');
        f.itemIndex.value = idx;
        f.fileName.value = d.fileName;
        f.partNumber.value = d.data.partNumber;
        f.quantity.value = d.data.quantity;
        f.deliveryDate.value = formatDateForInput(d.data.deliveryDate);
        f.orderDate.value = formatDateForInput(d.data.orderDate);
        f.customer.value = d.data.customer;
        f.mfgNumber.value = d.data.mfgNumber;
        f.orderNumber.value = d.data.orderNumber;
        
        document.getElementById('edit-modal').classList.remove('hidden');
        document.body.classList.add('modal-open');
      }

      // モーダルを閉じる
      function closeModal() {
        document.getElementById('edit-modal').classList.add('hidden');
        document.body.classList.remove('modal-open');
      }

      // 解析結果を破棄
      function discardResultFromModal() {
        const idx = document.getElementById('modal-form').itemIndex.value;
        if (!confirm('この解析結果を登録せずに破棄しますか？リストから消去されます。')) return;
        const card = document.getElementById(`card-${idx}`);
        if (card) card.remove();
        closeModal();
      }

      // モーダルから保存
      function saveFromModal() {
        const f = document.getElementById('modal-form');
        const idx = f.itemIndex.value;
        const data = { 
          fileName: f.fileName.value, 
          partNumber: f.partNumber.value, 
          quantity: f.quantity.value, 
          deliveryDate: f.deliveryDate.value.replace(/-/g, ''), 
          orderDate: f.orderDate.value.replace(/-/g, ''), 
          customer: f.customer.value, 
          mfgNumber: f.mfgNumber.value, 
          orderNumber: f.orderNumber.value
        };

        const saveBtn = document.querySelector('#edit-modal button[onclick="saveFromModal()"]');
        saveBtn.disabled = true;
        saveBtn.innerHTML = '<i class="fas fa-save mr-2"></i>保存中...';

        google.script.run
          .withSuccessHandler(() => {
            closeModal();
            saveBtn.disabled = false;
            saveBtn.innerHTML = '<i class="fas fa-save mr-2"></i>スプレッドシートに保存';
            
            const badge = document.getElementById(`status-${idx}`);
            badge.className = "text-[10px] font-bold text-green-600 bg-green-50 px-2 py-1 rounded border border-green-100 shadow-sm";
            badge.innerHTML = '<i class="fas fa-check mr-1"></i>保存済';
            badge.classList.remove('animate-pulse');
            
            const cardBtn = badge.parentElement.parentElement.querySelector('button');
            cardBtn.disabled = true;
            cardBtn.className = "w-full mt-3 bg-gray-50 border-2 border-gray-100 text-gray-400 py-2 rounded-lg text-xs font-bold cursor-not-allowed";
            cardBtn.innerHTML = "保存完了";
            
            loadHistory();
          })
          .withFailureHandler(err => {
            alert('保存に失敗しました: ' + err.message);
            saveBtn.disabled = false;
            saveBtn.innerHTML = '<i class="fas fa-save mr-2"></i>スプレッドシートに保存';
          })
          .saveToSheet(data);
      }

      // 日付フォーマット変換
      function formatDateForInput(s) {
        if (!s) return '';
        const m = s.match(/(\d{4})[\D]+(\d{1,2})[\D]+(\d{1,2})/);
        return m ? `${m[1]}-${m[2].padStart(2,'0')}-${m[3].padStart(2,'0')}` : '';
      }
    </script>
  </body>
</html>
