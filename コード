/**
 * スプレッドシートのURLを取得する
 */
function getSpreadsheetUrl() {
  return SpreadsheetApp.getActiveSpreadsheet().getUrl();
}

/**
 * シートを取得または作成する
 * シート名: 読み取りデータ
 */
function getTargetSheet() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const SHEET_NAME = '読み取りデータ'; 
  let sheet = ss.getSheetByName(SHEET_NAME);
  if (!sheet) {
    sheet = ss.insertSheet(SHEET_NAME);
    sheet.appendRow(['品番', '数量', '納期', '受注日', '客先', '製番', '注文番号', '登録日時', '画像', 'リストの有無', 'ピッキング', '受注入力', '生産準備', '解析ログ']);
    sheet.setFrozenRows(1);
  }
  return sheet;
}

/**
 * クライアントから送られた画像データを処理する
 */
function processImage(base64Data, fileName) {
  try {
    const apiKey = PropertiesService.getScriptProperties().getProperty('OCR_API_KEY');
    let extractedData = {};
    let mode = 'Drive API';
    let logMsg = "";

    console.log("--- 解析開始: " + fileName + " ---");

    if (apiKey) {
      try {
        const geminiResult = executeGeminiApi(base64Data, apiKey);
        console.log("解析レスポンス成功");
        
        extractedData = normalizeData(geminiResult);
        mode = 'AI解析'; 
        // 👇 変更箇所1：AIがどう解釈したか「生データ」をログに残す
        logMsg = "解析成功: " + JSON.stringify(geminiResult);
      } catch (e) {
        console.warn("AI解析失敗、Drive OCRに切り替えます: " + e.toString());
        const driveText = executeDriveApi(base64Data, fileName);
        extractedData = extractOrderDataWithRegex(driveText);
        mode = 'Drive API (Fallback)';
        logMsg = "AI失敗のためDrive OCR使用: " + e.message;
      }
    } else {
      const driveText = executeDriveApi(base64Data, fileName);
      extractedData = extractOrderDataWithRegex(driveText);
      logMsg = "APIキー未設定のためDrive OCR使用";
    }
    
    extractedData.analysisLog = logMsg;
    
    return { success: true, mode: mode, fileName: fileName, data: extractedData };
  } catch (e) {
    console.error("processImageエラー: " + e.toString());
    return { success: false, fileName: fileName, error: e.toString() };
  }
}

/**
 * AIからのレスポンスを整理する
 */
function normalizeData(data) {
  if (!data) return {};
  
  let source = Array.isArray(data) ? data[0] : data;
  if (source.data && typeof source.data === 'object') source = source.data;
  if (source.order && typeof source.order === 'object') source = source.order;

  const n = {};
  Object.keys(source).forEach(k => { 
    n[k.toLowerCase().replace(/[^a-z0-9]/g, '')] = source[k]; 
  });
  
  let part = String(n['partnumber'] || n['partname'] || n['code'] || n['itemcode'] || n['productcode'] || '');
  if (part) {
    part = part.split('(')[0].split('（')[0].trim();
  }

  let mfg = String(n['mfgnumber'] || n['serialnumber'] || n['no'] || n['jobnumber'] || n['seiban'] || '');
  if (mfg) {
    mfg = mfg.split(/[-－]/)[0].trim();
  }
  
  return {
    partNumber:   part,
    quantity:     String(n['quantity'] || n['qty'] || n['count'] || '').replace(/[^0-9.]/g, ''),
    deliveryDate: String(n['deliverydate'] || n['duedate'] || n['date'] || n['delivery'] || ''),
    orderDate:    String(n['orderdate'] || n['issuedate'] || n['order'] || ''),
    customer:     String(n['customer'] || n['customername'] || n['client'] || n['company'] || ''),
    mfgNumber:    mfg,
    orderNumber:  String(n['ordernumber'] || n['orderno'] || n['ponumber'] || n['po'] || '')
  };
}

/**
 * Gemini APIを実行
 */
function executeGeminiApi(base64Data, apiKey) {
  const modelId = "gemini-2.5-pro"; 
  const url = `https://generativelanguage.googleapis.com/v1beta/models/${modelId}:generateContent?key=${apiKey}`;
  
  const prompt = `
    注文書画像を解析し、以下の項目を正確に抽出してJSON形式で返してください。
    
    【抽出項目】
    1. partNumber: 品番コード。カッコ書きの数値や、後ろに続く品名などは含めず、純粋なコードのみを抽出してください。
    2. quantity: 数量。数値のみ。
    3. deliveryDate: 納期。
    4. orderDate: 注文日。
    5. customer: 客先名。
    6. mfgNumber: 製番。
    7. orderNumber: 注文番号。
    
    【ルール】
    - 返信は純粋なJSONオブジェクトのみ。Markdown装飾( \`\`\`json 等)は絶対に含めないでください。
    - 見つからない項目は空文字 "" にしてください。
  `;

  const payload = {
    contents: [{ 
      parts: [
        { text: prompt }, 
        { inline_data: { mime_type: base64Data.split(';')[0].split(':')[1], data: base64Data.split(',')[1] } }
      ] 
    }],
    generationConfig: { 
      response_mime_type: "application/json",
      temperature: 0.1
    }
  };
  
  const options = {
    method: 'post',
    contentType: 'application/json',
    payload: JSON.stringify(payload),
    muteHttpExceptions: true
  };

  const res = UrlFetchApp.fetch(url, options);
  const responseCode = res.getResponseCode();
  const responseText = res.getContentText();

  if (responseCode !== 200) {
    throw new Error(`APIエラー(${responseCode}): ${responseText}`);
  }

  const result = JSON.parse(responseText);
  if (result.candidates && result.candidates[0].content && result.candidates[0].content.parts) {
    let jsonString = result.candidates[0].content.parts[0].text;
    jsonString = jsonString.replace(/```json/g, "").replace(/```/g, "").trim();
    return JSON.parse(jsonString);
  }
  throw new Error("解析結果の構造が不正です。");
}

/**
 * スプレッドシートに保存
 */
function saveToSheet(f) {
  const sheet = getTargetSheet();
  const now = new Date();
  
  sheet.appendRow([
    f.partNumber, 
    f.quantity, 
    f.deliveryDate, 
    f.orderDate, 
    f.customer, 
    f.mfgNumber, 
    f.orderNumber, 
    now, 
    f.fileName,
    "", // リストの有無 (J列)
    "", // ピッキング (K列)
    "", // 受注入力 (L列)
    "", // 生産準備 (M列)
    f.analysisLog || ""  // 👇 変更箇所2：空文字ではなく解析ログを出力する
  ]);
  return { success: true };
}

/**
 * 履歴取得
 */
function getHistoryData() {
  try {
    const sheet = getTargetSheet();
    const lastRow = sheet.getLastRow();
    if (lastRow <= 1) return [];
    
    const lastCol = sheet.getLastColumn();
    const values = sheet.getRange(2, 1, lastRow - 1, lastCol).getValues();
    
    return values.map((row, index) => {
      const rawDate = row[7];
      let timestampStr = '-';
      let rawTimeId = String(index);

      if (rawDate instanceof Date) {
        timestampStr = Utilities.formatDate(rawDate, Session.getScriptTimeZone(), 'yyyy/MM/dd HH:mm');
        rawTimeId = String(rawDate.getTime());
      } else if (rawDate) {
        timestampStr = String(rawDate);
        rawTimeId = String(rawDate);
      }

      return {
        partNumber:   String(row[0] || ''),
        quantity:     String(row[1] || ''),
        deliveryDate: String(row[2] || ''),
        orderDate:    String(row[3] || ''),
        customer:     String(row[4] || ''),
        mfgNumber:    String(row[5] || ''),
        orderNumber:  String(row[6] || ''),
        timestamp:    timestampStr,
        rawTimestamp: rawTimeId,
        fileName:     String(row[8] || '')
      };
    }).reverse().slice(0, 50);
  } catch (e) {
    throw new Error(e.message);
  }
}

/**
 * データの削除
 */
function deleteHistoryItem(rawTimestamp, fileName) {
  const sheet = getTargetSheet();
  const lastRow = sheet.getLastRow();
  if (lastRow <= 1) return { success: false };
  const lastCol = sheet.getLastColumn(); 
  const values = sheet.getRange(2, 1, lastRow - 1, Math.max(lastCol, 9)).getValues(); 
  for (let i = 0; i < values.length; i++) {
    const d = values[i][7];
    const tid = (d instanceof Date) ? String(d.getTime()) : String(d || i);
    if (tid === String(rawTimestamp) && String(values[i][8] || '') === String(fileName)) {
      sheet.deleteRow(i + 2);
      return { success: true };
    }
  }
  return { success: false };
}

/**
 * Drive OCR Fallback
 */
function executeDriveApi(base64Data, fileName) {
  const data = base64Data.split(',')[1];
  const mimeType = base64Data.split(';')[0].split(':')[1];
  try {
    const url = "https://www.googleapis.com/upload/drive/v2/files?uploadType=multipart&ocr=true&convert=true&ocrLanguage=ja";
    const boundary = "-------ocr_boundary";
    const metadata = { title: "TempOCR_" + fileName, mimeType: mimeType };
    const payload = "--" + boundary + "\r\nContent-Type: application/json; charset=UTF-8\r\n\r\n" + JSON.stringify(metadata) + "\r\n--" + boundary + "\r\nContent-Type: " + mimeType + "\r\nContent-Transfer-Encoding: base64\r\n\r\n" + data + "\r\n--" + boundary + "--";
    const params = { method: "post", contentType: "multipart/related; boundary=" + boundary, payload: payload, headers: { Authorization: "Bearer " + ScriptApp.getOAuthToken() }, muteHttpExceptions: true };
    const res = UrlFetchApp.fetch(url, params);
    const fileId = JSON.parse(res.getContentText()).id;
    if (!fileId) throw new Error("Drive OCR失敗");
    const text = DocumentApp.openById(fileId).getBody().getText();
    DriveApp.getFileById(fileId).setTrashed(true);
    return text;
  } catch (e) {
    throw new Error("OCR失敗: " + e.message);
  }
}

/**
 * 正規表現抽出
 */
function extractOrderDataWithRegex(t) {
  const f = (r) => { const m = t.match(r); return m ? m[1].trim() : ''; };
  return {
    partNumber: f(/(?:品番|型番|Code|P\/N)[:：\s]*([A-Za-z0-9\-\.]+)/i),
    quantity: f(/(?:数量|数|Qty)[:：\s]*([0-9,]+)/i),
    deliveryDate: f(/(?:納期|納入日)[:：\s]*([0-9\/\-年]+)/i),
    orderDate: f(/(?:受注日|注文日)[:：\s]*([0-9\/\-年]+)/i),
    customer: f(/(?:客先|宛名|御中)[:：\s]*([^\n\r]+)/i),
    mfgNumber: f(/(?:製番|製造番号)[:：\s]*([A-Za-z0-9\-]+)/i),
    orderNumber: f(/(?:注文番号|オーダーNo)[:：\s]*([A-Za-z0-9\-]+)/i)
  };
}
